<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_order_form_bad" model="ir.ui.view">
        <field name="name">sale.order.form.bad</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[2]" position="after">
                <field name="x_custom_notes"/>
            </xpath>
        </field>
    </record>

    <record id="view_sale_order_form_bad" model="ir.ui.view">
        <field name="name">sale.order.form.duplicate</field>
        <field name="model">sale.order</field>
        <field name="arch" type="xml">
            <form/>
        </field>
    </record>
</odoo>
